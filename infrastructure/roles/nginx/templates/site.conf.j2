# Managed by Ansible — do not edit by hand.
# HTTP vhost; certbot's nginx plugin adds the 443/SSL server block and the
# 80 -> 443 redirect on top of this file.
server {
    listen 80;
    listen [::]:80;
    server_name {{ nginx_domain }};

    location / {
        proxy_pass http://127.0.0.1:{{ nginx_upstream_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # The live-chat feature streams to the browser over Server-Sent Events
        # (EventSource on /api/conversations/:id/stream, plus the streamed
        # /api/chat reply). nginx buffers proxied responses by default, which
        # holds an SSE stream indefinitely and makes live chat appear dead.
        # HTTP/1.1 with an empty Connection header keeps the upstream socket
        # streaming, and a long read timeout stops idle streams being culled
        # (the app also heartbeats every 15s — see apps/server/src/sse.ts).
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 1h;
    }
}
