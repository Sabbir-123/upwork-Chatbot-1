# AI (LLM) mode is chosen at runtime via the toggle at the top of the page.
# It is only *offered* when an OpenRouter API key is present here; otherwise the
# app runs rule-based only and the AI toggle is disabled. No key = fully testable offline.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-5

# Conversation persistence + pub/sub for the live-agent feature. When unset, the
# server falls back to an in-memory store (fine for local dev / tests, but state
# doesn't survive a restart and doesn't work across multiple replicas).
REDIS_URL=redis://localhost:6379
